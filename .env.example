# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=""

# STRIPE_SECRET_KEY: Stripe Secret Key (starts with sk_test_ for Test Mode, sk_live_ for Live Mode).
# If omitted or invalid, the applet automatically falls back to an elegant high-fidelity checkout simulation.
STRIPE_SECRET_KEY=""

# STRIPE_WEBHOOK_SECRET: Optional Stripe Webhook Signature Secret (whsec_...) for secure webhooks.
STRIPE_WEBHOOK_SECRET=""

# FIREBASE_SERVICE_ACCOUNT: Optional JSON string of the Firebase service account key.
# Required only if deploying outside of Google Cloud (such as on Vercel) to authorize server-side Firebase Admin actions.
FIREBASE_SERVICE_ACCOUNT=""

# FIRESTORE_DATABASE_ID: Optional database ID (leave blank or use "(default)" for production default database)
FIRESTORE_DATABASE_ID=""
